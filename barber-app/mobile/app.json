{
  "expo": {
    "name": "Barber App",
    "slug": "barber-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.barberapp"
    },
    "android": {
      "package": "com.barberapp",
      "permissions": ["NOTIFICATIONS"]
    },
    "plugins": [
      "expo-notifications"
    ]
  }
}
